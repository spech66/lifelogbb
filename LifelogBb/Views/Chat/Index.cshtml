@model LifelogBb.Models.Chat.ChatViewModel

@{
    ViewData["Title"] = "Chat";
}

<div class="container-xl">
    @Html.AntiForgeryToken()
    <div class="row row-cards">
        @if (!Model.IsConfigured)
        {
            <div class="col-12">
                <div class="alert alert-warning" role="alert">
                    <div class="d-flex">
                        <div><i class="fas fa-exclamation-triangle me-2"></i></div>
                        <div>
                            Chat is not configured. Please set your API key in the
                            <a asp-controller="Home" asp-action="Config" class="alert-link">Config page</a>.
                        </div>
                    </div>
                </div>
            </div>
        }
        <div class="col-12 col-md-3">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Chats</h3>
                    <div class="card-actions">
                        <form asp-action="CreateSession" method="post">
                            <button type="submit" class="btn btn-ghost-primary btn-sm" title="New chat">
                                <i class="fas fa-plus"></i>
                            </button>
                        </form>
                    </div>
                </div>
                <div class="list-group list-group-flush" style="max-height: 60vh; overflow-y: auto;">
                    @if (Model.Sessions.Count == 0)
                    {
                        <div class="list-group-item text-secondary text-center py-3">
                            No chats yet
                        </div>
                    }
                    @foreach (var session in Model.Sessions)
                    {
                        <div class="list-group-item list-group-item-action d-flex align-items-center @(session.Id == Model.ActiveSessionId ? "active" : "")"
                             id="session-@session.Id">
                            <a asp-action="Index" asp-route-id="@session.Id"
                               class="flex-grow-1 text-truncate text-decoration-none @(session.Id == Model.ActiveSessionId ? "text-white" : "")"
                               title="@session.Name">
                                @session.Name
                            </a>
                            <div class="d-flex gap-1 ms-2 flex-shrink-0">
                                <button class="btn btn-ghost-secondary btn-sm p-1 rename-session-btn"
                                        data-session-id="@session.Id" data-session-name="@session.Name"
                                        title="Rename">
                                    <i class="fas fa-pencil-alt" style="font-size: 0.7rem;"></i>
                                </button>
                                <form asp-action="DeleteSession" asp-route-id="@session.Id" method="post"
                                      class="d-inline delete-session-form">
                                    <button type="submit" class="btn btn-ghost-danger btn-sm p-1" title="Delete">
                                        <i class="fas fa-trash" style="font-size: 0.7rem;"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-12 col-md-9">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-comments me-2"></i>
                        <span id="active-session-name">@(Model.ActiveSessionName ?? "Chat")</span>
                    </h3>
                    <div class="card-actions">
                        <button class="btn btn-ghost-secondary btn-sm" id="clear-chat" title="Clear chat display">
                            <i class="fas fa-eraser"></i>
                        </button>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div id="chat-messages" style="height: 60vh; overflow-y: auto; padding: 1.5rem;">
                        @if (Model.Messages.Count == 0)
                        {
                            <div class="text-center text-secondary py-4" id="chat-placeholder">
                                <i class="fas fa-comments fa-3x mb-3 d-block"></i>
                                Ask me anything about your life tracking data.
                            </div>
                        }
                    </div>
                </div>
                <div class="card-footer">
                    <div class="d-flex gap-2">
                        <input type="text" id="chat-input" class="form-control form-control-lg"
                               placeholder="Type your message..." autocomplete="off"
                               @(Model.IsConfigured ? "" : "disabled") />
                        <button id="chat-send" class="btn btn-primary btn-lg px-4" aria-label="Send message"
                                @(Model.IsConfigured ? "" : "disabled")>
                            <i class="fas fa-paper-plane"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const messagesContainer = document.getElementById('chat-messages');
            const chatInput = document.getElementById('chat-input');
            const sendBtn = document.getElementById('chat-send');
            const clearBtn = document.getElementById('clear-chat');
            let placeholder = document.getElementById('chat-placeholder');
            const antiForgeryToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value
                || document.querySelector('meta[name="RequestVerificationToken"]')?.content
                || '';

            let currentSessionId = @(Model.ActiveSessionId.HasValue ? Model.ActiveSessionId.Value.ToString() : "null");
            let isLoading = false;

            // Render persisted messages on load
            const persistedMessages = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Messages, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));
            if (persistedMessages && persistedMessages.length > 0) {
                persistedMessages.forEach(function (msg) {
                    addMessage(msg.role, msg.content);
                });
            }

            function scrollToBottom() {
                messagesContainer.scrollTop = messagesContainer.scrollHeight;
            }

            function addMessage(role, content) {
                if (placeholder) {
                    placeholder.style.display = 'none';
                }

                const wrapper = document.createElement('div');
                wrapper.className = 'd-flex mb-3 ' + (role === 'user' ? 'justify-content-end' : 'justify-content-start');

                const bubble = document.createElement('div');
                bubble.className = 'p-3 rounded-3 ' + (role === 'user'
                    ? 'bg-primary text-white'
                    : 'bg-secondary-lt');
                bubble.style.maxWidth = '80%';
                bubble.style.wordBreak = 'break-word';
                if (role === 'assistant') {
                    bubble.innerHTML = content;
                } else {
                    bubble.style.whiteSpace = 'pre-wrap';
                    bubble.textContent = content;
                }

                wrapper.appendChild(bubble);
                messagesContainer.appendChild(wrapper);
                scrollToBottom();
            }

            function addLoadingIndicator() {
                const wrapper = document.createElement('div');
                wrapper.className = 'd-flex mb-3 justify-content-start';
                wrapper.id = 'loading-indicator';

                const bubble = document.createElement('div');
                bubble.className = 'p-3 rounded-3 bg-secondary-lt';
                bubble.innerHTML = '<div class="spinner-border spinner-border-sm me-2" role="status"></div>Thinking...';

                wrapper.appendChild(bubble);
                messagesContainer.appendChild(wrapper);
                scrollToBottom();
            }

            function removeLoadingIndicator() {
                const loading = document.getElementById('loading-indicator');
                if (loading) {
                    loading.remove();
                }
            }

            async function sendMessage() {
                const message = chatInput.value.trim();
                if (!message || isLoading) return;

                isLoading = true;
                sendBtn.disabled = true;
                chatInput.disabled = true;

                addMessage('user', message);
                chatInput.value = '';

                addLoadingIndicator();

                try {
                    const response = await fetch('@Url.Action("Send", "Chat")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': antiForgeryToken
                        },
                        body: JSON.stringify({
                            message: message,
                            sessionId: currentSessionId
                        })
                    });

                    removeLoadingIndicator();

                    if (!response.ok) {
                        addMessage('assistant', 'Error: Failed to get response. Please try again.');
                    } else {
                        const data = await response.json();
                        if (data.error) {
                            addMessage('assistant', 'Error: ' + data.error);
                        } else {
                            addMessage('assistant', data.response);
                            // Update session ID if a new session was created
                            if (data.sessionId && !currentSessionId) {
                                currentSessionId = data.sessionId;
                                // Reload to show the new session in sidebar
                                window.location.href = '@Url.Action("Index", "Chat")' + '?id=' + data.sessionId;
                                return;
                            }
                        }
                    }
                } catch (err) {
                    removeLoadingIndicator();
                    addMessage('assistant', 'Error: Could not connect to the server.');
                }

                isLoading = false;
                sendBtn.disabled = false;
                chatInput.disabled = false;
                chatInput.focus();
            }

            sendBtn.addEventListener('click', sendMessage);
            chatInput.addEventListener('keydown', function (e) {
                if (e.key === 'Enter' && !e.shiftKey) {
                    e.preventDefault();
                    sendMessage();
                }
            });

            // Clear just the visual display (messages stay in DB)
            clearBtn.addEventListener('click', function () {
                messagesContainer.innerHTML = '';
                const newPlaceholder = document.createElement('div');
                newPlaceholder.className = 'text-center text-secondary py-4';
                newPlaceholder.id = 'chat-placeholder';
                newPlaceholder.innerHTML = '<i class="fas fa-comments fa-3x mb-3 d-block"></i>Ask me anything about your life tracking data.';
                messagesContainer.appendChild(newPlaceholder);
                placeholder = newPlaceholder;
            });

            // Delete session confirmation
            document.querySelectorAll('.delete-session-form').forEach(function (form) {
                form.addEventListener('submit', function (e) {
                    if (!confirm('This chat will be deleted forever. Continue?')) {
                        e.preventDefault();
                    }
                });
            });

            // Rename session
            document.querySelectorAll('.rename-session-btn').forEach(function (btn) {
                btn.addEventListener('click', function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    const sessionId = this.dataset.sessionId;
                    const currentName = this.dataset.sessionName;
                    const newName = prompt('Enter new name:', currentName);
                    if (newName && newName.trim() && newName.trim() !== currentName) {
                        fetch('@Url.Action("RenameSession", "Chat")', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': antiForgeryToken
                            },
                            body: JSON.stringify({ id: parseInt(sessionId), name: newName.trim() })
                        }).then(function (res) { return res.json(); })
                          .then(function (data) {
                              if (data.success) {
                                  // Update sidebar link text
                                  var item = document.getElementById('session-' + sessionId);
                                  if (item) {
                                      var link = item.querySelector('a');
                                      if (link) {
                                          link.textContent = data.name;
                                          link.title = data.name;
                                      }
                                  }
                                  // Update header if this is the active session
                                  if (parseInt(sessionId) === currentSessionId) {
                                      document.getElementById('active-session-name').textContent = data.name;
                                  }
                              }
                          });
                    }
                });
            });

            chatInput.focus();
        });
    </script>
}
