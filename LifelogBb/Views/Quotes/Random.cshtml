@using LifelogBb.Utilities;
@model LifelogBb.Models.Entities.Quote

@{
    ViewData["Title"] = "Random Quote";
    ViewData["PrimaryAction"] = "create";
    ViewData["SecondaryAction"] = "random";
}

<div class="container-xl">
    <div class="row row-cards justify-content-center">
        <div class="col-lg-8 col-xl-7">
            <div class="card h-100">
                <div class="card-body d-flex flex-column">
                    <div class="text-muted small mb-2">
                        <i class="fa-regular fa-calendar me-1"></i>@Model.CreatedAt.ToString("yyyy-MM-dd")
                    </div>
                    <blockquote class="blockquote mb-3">
                        <p>@Model.Text</p>
                        @if (!string.IsNullOrWhiteSpace(Model.Author))
                        {
                            <footer class="blockquote-footer mb-0"><cite>@Model.Author</cite></footer>
                        }
                    </blockquote>
                    <div class="mt-auto">
                        @Html.DisplayFor(modelItem => Model.Category, "Category")
                        @Html.DisplayFor(modelItem => Model.Tags, "Tags")
                    </div>
                </div>
                <div class="card-footer d-flex gap-2">
                    <a class="btn btn-sm btn-outline-secondary flex-fill" asp-action="Random">
                        <i class="fa-solid fa-shuffle me-1"></i>Shuffle
                    </a>
                    <a class="btn btn-sm btn-outline-primary flex-fill" asp-action="Details" asp-route-id="@Model.Id">
                        <i class="fa-solid fa-list-alt me-1"></i>Details
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
