@using LifelogBb.Utilities;
@model LifelogBb.Models.Quotes.QuoteIndexViewModel

@{
    ViewData["Title"] = "Quotes";
    ViewData["PrimaryAction"] = "create";
    ViewData["SecondaryAction"] = "random";

    string SortButtonClass(string fieldName)
        => RazorPageExtensions.GetSortOrder(ViewData, fieldName) == ""
            ? "btn-outline-secondary"
            : "btn-outline-primary";

    string Excerpt(string? text, int maxLength = 180)
    {
        if (string.IsNullOrWhiteSpace(text)) return string.Empty;
        text = text.Trim();
        return text.Length <= maxLength ? text : $"{text[..maxLength].TrimEnd()}…";
    }
}

<div class="container-xl">
    <div class="row row-deck row-cards mb-3">
        <div class="col-6 col-lg-3">
            <div class="card card-sm">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-auto">
                            <span class="bg-primary text-white avatar"><i class="fa-solid fa-quote-right"></i></span>
                        </div>
                        <div class="col">
                            <div class="font-weight-medium">Total</div>
                            <div class="text-muted"><strong>@Model.TotalCount</strong> quotes</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card card-sm">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-auto">
                            <span class="bg-azure text-white avatar"><i class="fa-solid fa-user-pen"></i></span>
                        </div>
                        <div class="col">
                            <div class="font-weight-medium">With Author</div>
                            <div class="text-muted"><strong>@Model.WithAuthorCount</strong> attributed</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card card-sm">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-auto">
                            <span class="@(Model.UniqueAuthorsCount > 0 ? "bg-yellow" : "bg-muted") text-white avatar"><i class="fa-solid fa-users"></i></span>
                        </div>
                        <div class="col">
                            <div class="font-weight-medium">Authors</div>
                            <div class="@(Model.UniqueAuthorsCount > 0 ? "text-yellow" : "text-muted")"><strong>@Model.UniqueAuthorsCount</strong> unique</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card card-sm">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-auto">
                            <span class="@(Model.TaggedCount > 0 ? "bg-green" : "bg-muted") text-white avatar"><i class="fa-solid fa-tags"></i></span>
                        </div>
                        <div class="col">
                            <div class="font-weight-medium">Tagged</div>
                            <div class="@(Model.TaggedCount > 0 ? "text-green" : "text-muted")"><strong>@Model.TaggedCount</strong> organized</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.TotalCount == 0)
    {
        <div class="row row-cards">
            <div class="col-12">
                <div class="card">
                    <div class="card-body text-center text-muted py-5">
                        No quotes yet. <a asp-action="Create">Add your first quote</a>.
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row row-cards mb-3">
            <div class="col-12">
                <div class="card">
                    <div class="card-body d-flex flex-column flex-md-row align-items-md-center gap-2">
                        <div class="text-muted me-md-2">Sort by</div>
                        <div class="btn-list flex-wrap">
                            <a asp-action="Index" asp-route-sortOrder="@RazorPageExtensions.GetSortRoute(ViewData, "CreatedAt")" class="btn btn-sm @SortButtonClass("CreatedAt")">Date</a>
                            <a asp-action="Index" asp-route-sortOrder="@RazorPageExtensions.GetSortRoute(ViewData, "Text")" class="btn btn-sm @SortButtonClass("Text")">Text</a>
                            <a asp-action="Index" asp-route-sortOrder="@RazorPageExtensions.GetSortRoute(ViewData, "Author")" class="btn btn-sm @SortButtonClass("Author")">Author</a>
                            <a asp-action="Index" asp-route-sortOrder="@RazorPageExtensions.GetSortRoute(ViewData, "Category")" class="btn btn-sm @SortButtonClass("Category")">Category</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row row-cards">
            @foreach (var item in Model.List)
            {
                <div class="col-sm-6 col-lg-4">
                    <div class="card h-100">
                        <div class="card-body d-flex flex-column">
                            <div class="text-muted small mb-2">
                                <i class="fa-regular fa-calendar me-1"></i>@item.CreatedAt.ToString("yyyy-MM-dd")
                            </div>
                            <blockquote class="blockquote mb-3">
                                <p>@Excerpt(item.Text)</p>
                                @if (!string.IsNullOrWhiteSpace(item.Author))
                                {
                                    <footer class="blockquote-footer mb-0"><cite>@item.Author</cite></footer>
                                }
                            </blockquote>
                            <div class="mt-auto">
                                @Html.DisplayFor(m => item.Category, "Category")
                                @Html.DisplayFor(m => item.Tags, "Tags")
                            </div>
                        </div>
                        <div class="card-footer d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary flex-fill">
                                <i class="fa-solid fa-pen me-1"></i>Edit
                            </a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary flex-fill">
                                <i class="fa-solid fa-list-alt me-1"></i>Details
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="row row-cards mt-3">
            <div class="col-12">
                <div class="card">
                    <div class="card-body d-flex align-items-center">
                        @await Component.InvokeAsync("Pagination", Model.List)
                    </div>
                </div>
            </div>
        </div>
    }
</div>
