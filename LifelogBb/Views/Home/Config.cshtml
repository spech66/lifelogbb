@using LifelogBb.Models.Entities
@using LifelogBb.Models.Home
@model EditConfigViewModel

@{
    ViewData["Title"] = "Config";
}

<form asp-action="Config">
    <div class="container-xl">
        <div class="row row-cards">
            @if (ViewData.ModelState.ErrorCount > 0)
            {
                <div class="col-12">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                </div>
            }
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Global</h3>
                    </div>
                    <div class="card-body">
                        <div class="form-group mb-3">
                            <label asp-for="StartOfWeek" class="control-label mb-1"></label>
                            <select asp-for="StartOfWeek" asp-items="@Html.GetEnumSelectList(typeof(DayOfWeek))" class="form-select"></select>
                            <span asp-validation-for="StartOfWeek" class="text-danger"></span>
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="UnitsType" class="control-label mb-1"></label>
                            <select asp-for="UnitsType" asp-items="@Html.GetEnumSelectList(typeof(LifelogBb.Models.Entities.Measurements))" class="form-select"></select>
                            <span class="text-warning">This won't change existing values!</span>
                            <span asp-validation-for="UnitsType" class="text-danger"></span>
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="Height" class="control-label mb-1"></label>
                            <input asp-for="Height" class="form-control form-control-lg" aria-describedby="height-help-text" />
                            <span id="height-help-text" class="text-secondary">@Model.HeightHelpText</span>
                            <span asp-validation-for="Height" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="card-footer text-end">
                        <div class="d-flex">
                            <a class="btn btn-secondary" asp-action="Index"><i class="fas fa-arrow-circle-left icon"></i>Back</a>
                            <button type="submit" value="Save" class="btn btn-primary ms-auto"><i class="fas fa-pen icon"></i>Submit</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Page sizes</h3>
                    </div>
                    <div class="card-body">
                        <div class="form-group mb-3">
                            <label asp-for="BucketListPageSize" class="control-label mb-1"></label>
                            <input asp-for="BucketListPageSize" class="form-control form-control-lg" />
                            <span asp-validation-for="BucketListPageSize" class="text-danger"></span>
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="WeightPageSize" class="control-label mb-1"></label>
                            <input asp-for="WeightPageSize" class="form-control form-control-lg" />
                            <span asp-validation-for="WeightPageSize" class="text-danger"></span>
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="GoalPageSize" class="control-label mb-1"></label>
                            <input asp-for="GoalPageSize" class="form-control form-control-lg" />
                            <span asp-validation-for="GoalPageSize" class="text-danger"></span>
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="HabitPageSize" class="control-label mb-1"></label>
                            <input asp-for="HabitPageSize" class="form-control form-control-lg" />
                            <span asp-validation-for="HabitPageSize" class="text-danger"></span>
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="JournalPageSize" class="control-label mb-1"></label>
                            <input asp-for="JournalPageSize" class="form-control form-control-lg" />
                            <span asp-validation-for="JournalPageSize" class="text-danger"></span>
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="QuotePageSize" class="control-label mb-1"></label>
                            <input asp-for="QuotePageSize" class="form-control form-control-lg" />
                            <span asp-validation-for="QuotePageSize" class="text-danger"></span>
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="StrengthTrainingPageSize" class="control-label mb-1"></label>
                            <input asp-for="StrengthTrainingPageSize" class="form-control form-control-lg" />
                            <span asp-validation-for="StrengthTrainingPageSize" class="text-danger"></span>
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="EnduranceTrainingPageSize" class="control-label mb-1"></label>
                            <input asp-for="EnduranceTrainingPageSize" class="form-control form-control-lg" />
                            <span asp-validation-for="EnduranceTrainingPageSize" class="text-danger"></span>
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="TodoPageSize" class="control-label mb-1"></label>
                            <input asp-for="TodoPageSize" class="form-control form-control-lg" />
                            <span asp-validation-for="TodoPageSize" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="card-footer text-end">
                        <div class="d-flex">
                            <a class="btn btn-secondary" asp-action="Index"><i class="fas fa-arrow-circle-left icon"></i>Back</a>
                            <button type="submit" value="Save" class="btn btn-primary ms-auto"><i class="fas fa-pen icon"></i>Submit</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Feed</h3>
                    </div>
                    <div class="card-body">
                        <div class="form-group mb-3">
                            <label asp-for="FeedTimeZone" class="control-label mb-1"></label>
                            <input asp-for="FeedTimeZone" class="form-control form-control-lg" />
                            <span asp-validation-for="FeedTimeZone" class="text-danger"></span>
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="FeedToken" class="control-label mb-1"></label>
                            <input asp-for="FeedToken" class="form-control form-control-lg" />
                            <span asp-validation-for="FeedToken" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="card-footer text-end">
                        <div class="d-flex">
                            <a class="btn btn-secondary" asp-action="Index"><i class="fas fa-arrow-circle-left icon"></i>Back</a>
                            <button type="submit" value="Save" class="btn btn-primary ms-auto"><i class="fas fa-pen icon"></i>Submit</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Weight</h3>
                    </div>
                    <div class="card-body">
                        <div class="form-group mb-3">
                            <label asp-for="WeightWarning" class="control-label mb-1"></label>
                            <input asp-for="WeightWarning" class="form-control form-control-lg" />
                            <span asp-validation-for="WeightWarning" class="text-danger"></span>
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="WeightWarningText" class="control-label mb-1"></label>
                            <input asp-for="WeightWarningText" class="form-control form-control-lg" />
                            <span asp-validation-for="WeightWarningText" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="card-footer text-end">
                        <div class="d-flex">
                            <a class="btn btn-secondary" asp-action="Index"><i class="fas fa-arrow-circle-left icon"></i>Back</a>
                            <button type="submit" value="Save" class="btn btn-primary ms-auto"><i class="fas fa-pen icon"></i>Submit</button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Chat / AI</h3>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-info" role="alert">
                            <h4 class="alert-title">MCP Server</h4>
                            <div class="text-secondary">LifelogBB includes a built-in <strong>Model Context Protocol (MCP)</strong> server at <code>/mcp</code>. Connect AI assistants (e.g. Claude Desktop, GitHub Copilot, Cursor) by providing your instance URL and a JWT Bearer token obtained from <a href="/Swagger/" target="_blank">Swagger UI</a> via <code>/api/authentication/token</code>.</div>
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="ChatEndpoint" class="control-label mb-1"></label>
                            <input asp-for="ChatEndpoint" class="form-control form-control-lg" placeholder="https://api.openai.com/v1/chat/completions" />
                            <span asp-validation-for="ChatEndpoint" class="text-danger"></span>
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="ChatApiKey" class="control-label mb-1"></label>
                            <input asp-for="ChatApiKey" type="password" class="form-control form-control-lg" placeholder="sk-..." autocomplete="new-password" />
                            @if (Model.HasChatApiKey)
                            {
                                <div class="form-hint">An API key is already configured. Leave this blank to keep the existing key.</div>
                            }
                            <span asp-validation-for="ChatApiKey" class="text-danger"></span>
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="ChatModel" class="control-label mb-1"></label>
                            <input asp-for="ChatModel" class="form-control form-control-lg" placeholder="gpt-4o" />
                            <span asp-validation-for="ChatModel" class="text-danger"></span>
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="ChatSystemPrompt" class="control-label mb-1"></label>
                            <textarea asp-for="ChatSystemPrompt" class="form-control form-control-lg" rows="4"></textarea>
                            <span asp-validation-for="ChatSystemPrompt" class="text-danger"></span>
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="ChatMaxToolRoundtrips" class="control-label mb-1"></label>
                            <input asp-for="ChatMaxToolRoundtrips" class="form-control form-control-lg" type="number" min="1" max="50" />
                            <span asp-validation-for="ChatMaxToolRoundtrips" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="card-footer text-end">
                        <div class="d-flex">
                            <a class="btn btn-secondary" asp-action="Index"><i class="fas fa-arrow-circle-left icon"></i>Back</a>
                            <button type="submit" value="Save" class="btn btn-primary ms-auto"><i class="fas fa-pen icon"></i>Submit</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <input type="hidden" asp-for="Id" />
</form>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const unitsSelect = document.getElementById('UnitsType');
            const heightHelpText = document.getElementById('height-help-text');

            if (!unitsSelect || !heightHelpText) {
                return;
            }

            const metricText = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.HeightHelpTextMetric));
            const imperialText = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.HeightHelpTextImperial));
            const imperialUnitsType = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(((int)Measurements.Imperial).ToString()));

            const updateHeightHelpText = function () {
                heightHelpText.textContent = unitsSelect.value === imperialUnitsType ? imperialText : metricText;
            };

            unitsSelect.addEventListener('change', updateHeightHelpText);
            updateHeightHelpText();
        });
    </script>
}
