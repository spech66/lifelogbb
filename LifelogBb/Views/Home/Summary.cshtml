@using LifelogBb.Models.Home
@using Microsoft.AspNetCore.Mvc.Rendering
@model SummaryViewModel

@{
    ViewData["Title"] = "Summary";

    var granularityOptions = Enum.GetValues<SummaryGranularity>()
        .Select(g => new SelectListItem(g.ToString(), g.ToString(), g == Model.Granularity))
        .ToList();

    var latestWeight = Model.Weights.LastOrDefault();
    var previousWeight = Model.Weights.Count > 1 ? Model.Weights[^2] : null;
    var priorityTodos = Model.Todos
        .Where(t => !t.IsCompleted)
        .OrderByDescending(t => t.IsImportant)
        .ThenBy(t => t.DueDate ?? DateTime.MaxValue)
        .Take(5)
        .ToList();
    var focusGoals = Model.Goals
        .Where(g => !g.IsCompleted)
        .OrderBy(g => g.EndDate ?? DateTime.MaxValue)
        .Take(5)
        .ToList();
    var recentJournals = Model.Journals.Take(3).ToList();
    var recentQuotes = Model.Quotes.Take(3).ToList();
    var recentBucketLists = Model.BucketLists.Take(3).ToList();
    var recentWorkouts = Model.StrengthTrainings
        .Select(s => new { Date = s.CreatedAt, Title = s.Exercise, Meta = $"{s.Weight:0.##} × {s.Reps}", Type = "Strength", Badge = "bg-azure-lt text-azure", Icon = "fa-dumbbell" })
        .Concat(Model.EnduranceTrainings.Select(e => new { Date = e.CreatedAt, Title = e.Exercise, Meta = $"{e.Distance:0.##} km{(e.Duration.HasValue ? $" · {e.Duration:hh\\:mm\\:ss}" : string.Empty)}", Type = "Endurance", Badge = "bg-green-lt text-green", Icon = "fa-person-running" }))
        .OrderByDescending(x => x.Date)
        .Take(5)
        .ToList();
    var notesCount = Model.Journals.Count + Model.Quotes.Count + Model.BucketLists.Count;

    string Excerpt(string? text, int maxLength = 120)
    {
        if (string.IsNullOrWhiteSpace(text)) return string.Empty;
        text = text.Trim();
        return text.Length <= maxLength ? text : $"{text[..maxLength].TrimEnd()}…";
    }

    int? GoalProgress(LifelogBb.Models.Entities.Goal goal)
    {
        if (goal.TargetValue == null || goal.CurrentValue == null || goal.InitialValue == null) return null;
        var diffTarget = goal.TargetValue < goal.InitialValue
            ? goal.InitialValue.Value - goal.TargetValue.Value
            : goal.TargetValue.Value - goal.InitialValue.Value;
        if (diffTarget == 0) return null;
        var diffCurrent = goal.TargetValue < goal.InitialValue
            ? goal.InitialValue.Value - goal.CurrentValue.Value
            : goal.CurrentValue.Value - goal.InitialValue.Value;
        return (int)Math.Round(Math.Clamp((diffCurrent / diffTarget) * 100, 0, 100));
    }

    string GoalDueClass(LifelogBb.Models.Entities.Goal goal)
    {
        if (!goal.EndDate.HasValue) return "bg-muted-lt text-muted";
        if (goal.EndDate.Value.Date < DateTime.Today) return "bg-red-lt text-red";
        if (goal.EndDate.Value.Date == DateTime.Today) return "bg-orange-lt text-orange";
        return "bg-yellow-lt text-yellow";
    }

    string GoalDueLabel(LifelogBb.Models.Entities.Goal goal)
    {
        if (!goal.EndDate.HasValue) return "No due date";
        if (goal.EndDate.Value.Date < DateTime.Today) return $"Overdue · {goal.EndDate:yyyy-MM-dd}";
        if (goal.EndDate.Value.Date == DateTime.Today) return "Due today";
        return goal.EndDate.Value.ToString("yyyy-MM-dd");
    }
}

<div class="container-xl">
    <div class="row row-cards mb-3">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex flex-column flex-xl-row align-items-xl-center justify-content-between gap-3 mb-3">
                        <div>
                            <div class="text-muted text-uppercase small fw-bold">Range</div>
                            <h3 class="card-title mb-0">@Model.RangeLabel</h3>
                        </div>
                        <div class="btn-list flex-wrap">
                            @foreach (var item in Enum.GetValues<SummaryGranularity>())
                            {
                                <a asp-action="Summary"
                                   asp-route-granularity="@item"
                                   asp-route-start="@Model.Start.ToString("yyyy-MM-dd")"
                                   asp-route-end="@Model.End.ToString("yyyy-MM-dd")"
                                   class="btn btn-sm @(item == Model.Granularity ? "btn-primary" : "btn-outline-secondary")">
                                    @item
                                </a>
                            }
                        </div>
                    </div>

                    <form asp-action="Summary" method="get" class="row g-3 align-items-end">
                        <div class="col-12 col-lg-3">
                            <label class="form-label">Granularity</label>
                            <select id="granularity" name="granularity" asp-items="granularityOptions" class="form-select form-select-lg"></select>
                        </div>
                        <div class="col-12 col-lg-3">
                            <label class="form-label">Start</label>
                            <input id="start" type="date" name="start" class="form-control form-control-lg" value="@Model.Start.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-12 col-lg-3">
                            <label class="form-label">End</label>
                            <input id="end" type="date" name="end" class="form-control form-control-lg" value="@Model.End.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-12 col-lg-3">
                            <button type="submit" class="btn btn-primary btn-lg w-100">
                                <i class="fa-solid fa-filter me-1"></i>Update summary
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="row row-deck row-cards mb-3">
        <div class="col-6 col-lg-3">
            <div class="card card-sm h-100">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-auto">
                            <span class="bg-primary text-white avatar"><i class="fa-solid fa-chart-simple"></i></span>
                        </div>
                        <div class="col">
                            <div class="font-weight-medium">Tracked Items</div>
                            <div class="text-muted"><strong>@Model.TotalEntries</strong> in range</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card card-sm h-100">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-auto">
                            <span class="@(Model.WorkoutsCount > 0 ? "bg-azure" : "bg-muted") text-white avatar"><i class="fa-solid fa-dumbbell"></i></span>
                        </div>
                        <div class="col">
                            <div class="font-weight-medium">Workouts</div>
                            <div class="text-muted"><strong>@Model.WorkoutsCount</strong> sessions</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card card-sm h-100">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-auto">
                            <span class="@(Model.OpenTodosCount > 0 ? "bg-orange" : "bg-muted") text-white avatar"><i class="fa-solid fa-list-check"></i></span>
                        </div>
                        <div class="col">
                            <div class="font-weight-medium">Todos</div>
                            <div class="text-muted"><strong>@Model.OpenTodosCount</strong> open</div>
                            <div class="text-muted small">@Model.CompletedTodosCount completed</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card card-sm h-100">
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-auto">
                            <span class="@(notesCount > 0 ? "bg-green" : "bg-muted") text-white avatar"><i class="fa-solid fa-book-open"></i></span>
                        </div>
                        <div class="col">
                            <div class="font-weight-medium">Notes & Inspiration</div>
                            <div class="text-muted"><strong>@notesCount</strong> entries</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.TotalEntries == 0)
    {
        <div class="row row-cards">
            <div class="col-12">
                <div class="card">
                    <div class="card-body text-center text-muted py-5">
                        No entries found for this range.
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row row-deck row-cards mb-3">
            <div class="col-lg-7">
                <div class="card h-100">
                    <div class="card-header border-0">
                        <h3 class="card-title">Focus</h3>
                    </div>
                    <div class="card-body">
                        <div class="mb-4">
                            <div class="text-muted text-uppercase small fw-bold mb-2">Priority Todos</div>
                            @if (priorityTodos.Count == 0)
                            {
                                <div class="text-muted">No open todos in this range.</div>
                            }
                            else
                            {
                                <div class="list-group list-group-flush border rounded">
                                    @foreach (var todo in priorityTodos)
                                    {
                                        <a asp-controller="Todos" asp-action="Details" asp-route-id="@todo.Id" class="list-group-item list-group-item-action py-3">
                                            <div class="d-flex align-items-start justify-content-between gap-3">
                                                <div>
                                                    <div class="fw-medium">@todo.Title</div>
                                                    @if (!string.IsNullOrWhiteSpace(todo.Description))
                                                    {
                                                        <div class="text-muted small">@Excerpt(todo.Description, 90)</div>
                                                    }
                                                </div>
                                                <div class="text-end">
                                                    @if (todo.IsImportant)
                                                    {
                                                        <div class="text-yellow small"><i class="fa-solid fa-star me-1"></i>Important</div>
                                                    }
                                                    @if (todo.DueDate.HasValue)
                                                    {
                                                        <div class="text-muted small mt-1">@todo.DueDate.Value.ToString("yyyy-MM-dd HH:mm")</div>
                                                    }
                                                </div>
                                            </div>
                                        </a>
                                    }
                                </div>
                            }
                        </div>

                        <div>
                            <div class="text-muted text-uppercase small fw-bold mb-2">Goals</div>
                            @if (focusGoals.Count == 0)
                            {
                                <div class="text-muted">No active goals in this range.</div>
                            }
                            else
                            {
                                <div class="d-flex flex-column gap-2">
                                    @foreach (var goal in focusGoals)
                                    {
                                        var progress = GoalProgress(goal);
                                        <a asp-controller="Goals" asp-action="Details" asp-route-id="@goal.Id" class="card card-sm text-reset">
                                            <div class="card-body py-3">
                                                <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                                                    <div class="fw-medium">@goal.Name</div>
                                                    <span class="badge @GoalDueClass(goal)">@GoalDueLabel(goal)</span>
                                                </div>
                                                @if (progress.HasValue)
                                                {
                                                    <div class="mb-1 d-flex justify-content-between small text-muted">
                                                        <span>@goal.InitialValue?.ToString("0.##") → @goal.TargetValue?.ToString("0.##")</span>
                                                        <span>@goal.CurrentValue?.ToString("0.##") (@progress%)</span>
                                                    </div>
                                                    <div class="progress" style="height: 6px;">
                                                        <div class="progress-bar @(progress >= 100 ? "bg-green" : "bg-primary")" style="width: @progress%"></div>
                                                    </div>
                                                }
                                            </div>
                                        </a>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                    <div class="card-footer d-flex gap-2">
                        <a asp-controller="Todos" asp-action="Index" class="btn btn-sm btn-outline-secondary flex-fill">Todos</a>
                        <a asp-controller="Goals" asp-action="Index" class="btn btn-sm btn-outline-primary flex-fill">Goals</a>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="card h-100">
                    <div class="card-header border-0">
                        <h3 class="card-title">Health & Training</h3>
                    </div>
                    <div class="card-body">
                        <div class="mb-4">
                            <div class="text-muted text-uppercase small fw-bold mb-2">Weight</div>
                            @if (latestWeight == null)
                            {
                                <div class="text-muted">No weight entries in this range.</div>
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-between gap-3 mb-2">
                                    <div>
                                        <div class="h3 mb-0">@latestWeight.BodyWeight.ToString("0.0")</div>
                                        <div class="text-muted small">BMI @latestWeight.Bmi.ToString("0.00")</div>
                                    </div>
                                    <div class="text-end small">
                                        @if (previousWeight != null)
                                        {
                                            var change = latestWeight.BodyWeight - previousWeight.BodyWeight;
                                            <span class="@(change < 0 ? "text-green" : change > 0 ? "text-red" : "text-muted")">
                                                @if (change > 0)
                                                {
                                                    <i class="fa-solid fa-arrow-up"></i>
                                                }
                                                else if (change < 0)
                                                {
                                                    <i class="fa-solid fa-arrow-down"></i>
                                                }
                                                else
                                                {
                                                    <i class="fa-solid fa-minus"></i>
                                                }
                                                @change.ToString("+0.0;-0.0;0.0")
                                            </span>
                                        }
                                        <div class="text-muted">@latestWeight.CreatedAt.ToString("yyyy-MM-dd")</div>
                                    </div>
                                </div>
                            }
                        </div>

                        <div>
                            <div class="text-muted text-uppercase small fw-bold mb-2">Recent Workouts</div>
                            @if (recentWorkouts.Count == 0)
                            {
                                <div class="text-muted">No workouts in this range.</div>
                            }
                            else
                            {
                                <div class="list-group list-group-flush border rounded">
                                    @foreach (var workout in recentWorkouts)
                                    {
                                        <div class="list-group-item py-3">
                                            <div class="d-flex align-items-start justify-content-between gap-3">
                                                <div>
                                                    <div class="d-flex align-items-center gap-2 mb-1">
                                                        <span class="badge @workout.Badge"><i class="fa-solid @workout.Icon me-1"></i>@workout.Type</span>
                                                    </div>
                                                    <div class="fw-medium">@workout.Title</div>
                                                    <div class="text-muted small">@workout.Meta</div>
                                                </div>
                                                <div class="text-muted small">@workout.Date.ToString("yyyy-MM-dd")</div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                    <div class="card-footer d-flex gap-2">
                        <a asp-controller="Weights" asp-action="Index" class="btn btn-sm btn-outline-secondary flex-fill">Weight</a>
                        <a asp-controller="StrengthTrainings" asp-action="Index" class="btn btn-sm btn-outline-primary flex-fill">Strength</a>
                        <a asp-controller="EnduranceTrainings" asp-action="Index" class="btn btn-sm btn-outline-primary flex-fill">Endurance</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="row row-deck row-cards">
            <div class="col-lg-6">
                <div class="card h-100">
                    <div class="card-header border-0">
                        <h3 class="card-title">Journal Highlights</h3>
                    </div>
                    <div class="card-body">
                        @if (recentJournals.Count == 0)
                        {
                            <div class="text-muted">No journal entries in this range.</div>
                        }
                        else
                        {
                            <div class="d-flex flex-column gap-2">
                                @foreach (var journal in recentJournals)
                                {
                                    <a asp-controller="Journals" asp-action="Details" asp-route-id="@journal.Id" class="card card-sm text-reset">
                                        <div class="card-body py-3">
                                            <div class="text-muted small mb-1">@journal.Date.ToString("yyyy-MM-dd")</div>
                                            <div class="fw-medium mb-1">Journal entry</div>
                                            <div class="text-muted small">@Excerpt(journal.Text, 160)</div>
                                        </div>
                                    </a>
                                }
                            </div>
                        }
                    </div>
                    <div class="card-footer">
                        <a asp-controller="Journals" asp-action="Index" class="btn btn-sm btn-outline-secondary w-100">Open Journals</a>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="card h-100">
                    <div class="card-header border-0">
                        <h3 class="card-title">Inspiration</h3>
                    </div>
                    <div class="card-body d-flex flex-column gap-3">
                        @if (recentQuotes.Count > 0)
                        {
                            var quote = recentQuotes[0];
                            <div>
                                <div class="text-muted text-uppercase small fw-bold mb-2">Latest Quote</div>
                                <blockquote class="blockquote mb-0">
                                    <p>@Excerpt(quote.Text, 180)</p>
                                    @if (!string.IsNullOrWhiteSpace(quote.Author))
                                    {
                                        <footer class="blockquote-footer mb-0"><cite>@quote.Author</cite></footer>
                                    }
                                </blockquote>
                            </div>
                        }
                        else
                        {
                            <div class="text-muted">No quotes in this range.</div>
                        }

                        @if (recentBucketLists.Count > 0)
                        {
                            <div>
                                <div class="text-muted text-uppercase small fw-bold mb-2">Bucket List</div>
                                <div class="list-group list-group-flush border rounded">
                                    @foreach (var bucket in recentBucketLists)
                                    {
                                        <a asp-controller="BucketLists" asp-action="Details" asp-route-id="@bucket.Id" class="list-group-item list-group-item-action py-3">
                                            <div class="fw-medium">@bucket.Title</div>
                                            @if (!string.IsNullOrWhiteSpace(bucket.Description))
                                            {
                                                <div class="text-muted small mt-1">@Excerpt(bucket.Description, 90)</div>
                                            }
                                        </a>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                    <div class="card-footer d-flex gap-2">
                        <a asp-controller="Quotes" asp-action="Index" class="btn btn-sm btn-outline-secondary flex-fill">Quotes</a>
                        <a asp-controller="BucketLists" asp-action="Index" class="btn btn-sm btn-outline-primary flex-fill">Bucket List</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
    const granularityEl = document.getElementById('granularity');
    const startEl = document.getElementById('start');
    const endEl = document.getElementById('end');

    // Map granularity to days to add (except Custom)
    const granularityDays = {
        'Day': 0,
        'Week': 6,
        'Month': 29,
        'Year': 364
    };

    function setEndState() {
        const granularity = granularityEl.value;
        
        if(granularity === 'All') {
            startEl.disabled = true;
            startEl.classList.add('bg-light');
        } else {
            startEl.disabled = false;
            startEl.classList.remove('bg-light');
        }

        if (granularity === 'Custom') {
            endEl.disabled = false;
            endEl.classList.remove('bg-light');
        } else {
            // Calculate end date
            const startDate = startEl.value;
            if (startDate) {
                const start = new Date(startDate);
                const days = granularityDays[granularity];
                if (typeof days !== 'undefined') {
                    const end = new Date(start);
                    end.setDate(end.getDate() + days);
                    // Format as yyyy-MM-dd
                    const yyyy = end.getFullYear();
                    const mm = String(end.getMonth() + 1).padStart(2, '0');
                    const dd = String(end.getDate()).padStart(2, '0');
                    endEl.value = `${yyyy}-${mm}-${dd}`;
                }
            }
            endEl.disabled = true;
            endEl.classList.add('bg-light');
        }
    }

    granularityEl.addEventListener('change', setEndState);
    startEl.addEventListener('change', setEndState);
    // On page load
    document.addEventListener('DOMContentLoaded', setEndState);
    // Also run immediately in case DOMContentLoaded already fired
    setEndState();
</script>
}
