@{
    var filtersJson = ViewBag.FiltersJson as string ?? "[]";
    var currentFilterJson = ViewBag.CurrentFilterJson as string;
}

<link rel="stylesheet" href="~/lib/jquery-querybuilder/css/query-builder.default.css" />

<div class="card mb-3">
    <div class="card-header">
        <h3 class="card-title">
            <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-filter" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path d="M4 4h16v2.172a2 2 0 0 1 -.586 1.414l-4.414 4.414v7l-6 2v-8.5l-4.48 -4.928a2 2 0 0 1 -.52 -1.345v-2.227z"></path></svg>
            Advanced Filter
        </h3>
        <div class="card-actions">
            <a href="#" class="btn btn-sm" data-bs-toggle="collapse" data-bs-target="#filterBuilderCollapse">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon icon-tabler icon-tabler-chevron-down" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path d="M6 9l6 6l6 -6"></path></svg>
            </a>
        </div>
    </div>
    <div id="filterBuilderCollapse" class="collapse @(string.IsNullOrEmpty(currentFilterJson) ? "" : "show")">
        <div class="card-body">
            <div id="query-builder"></div>
        </div>
        <div class="card-footer text-end">
            <button type="button" id="btn-filter-clear" class="btn btn-ghost-secondary me-2">Clear</button>
            <button type="button" id="btn-filter-apply" class="btn btn-primary">Apply Filter</button>
            <div id="filter-limit-warning" class="alert alert-warning mt-2 mb-0 text-start d-none" role="alert" aria-live="assertive"></div>
        </div>
    </div>
</div>

<script>
    (function () {
        var maxDepth = 5;
        var maxConditions = 20;
        var filters = @Html.Raw(filtersJson);
        var currentFilterValue = @Html.Raw(currentFilterJson is null ? "null" : currentFilterJson);
        var parsedFilter = currentFilterValue || null;

        // Operator mapping: QueryBuilder operator name => our ComparisonOperator enum name
        var operatorMap = {
            'equal': 'Equal',
            'not_equal': 'NotEqual',
            'greater': 'GreaterThan',
            'greater_or_equal': 'GreaterThanOrEqual',
            'less': 'LessThan',
            'less_or_equal': 'LessThanOrEqual',
            'contains': 'Contains',
            'not_contains': 'NotContains',
            'in': 'In',
            'not_in': 'NotIn'
        };

        // Reverse map: our enum name => QueryBuilder operator name
        var reverseOperatorMap = {};
        for (var key in operatorMap) {
            reverseOperatorMap[operatorMap[key]] = key;
        }

        $('#query-builder').queryBuilder({
            filters: filters,
            allow_groups: maxDepth,
            rules: parsedFilter ? fromServerFormat(parsedFilter) : undefined
        });

        // Convert server FilterGroup format to QueryBuilder rules format
        function fromServerFormat(serverGroup) {
            var rules = {
                condition: serverGroup.operator === 'Or' ? 'OR' : 'AND',
                rules: []
            };

            if (serverGroup.conditions) {
                serverGroup.conditions.forEach(function (cond) {
                    var qbOperator = reverseOperatorMap[cond.operator] || 'equal';
                    var value = cond.value;
                    if (qbOperator === 'in' || qbOperator === 'not_in') {
                        if (typeof value !== 'string') {
                            value = '';
                        }
                        value = value
                            ? value.split(',').map(function (v) { return v.trim(); })
                            : [];
                    }
                    rules.rules.push({
                        id: cond.field,
                        operator: qbOperator,
                        value: value
                    });
                });
            }

            if (serverGroup.groups) {
                serverGroup.groups.forEach(function (g) {
                    rules.rules.push(fromServerFormat(g));
                });
            }

            return rules;
        }

        // Convert QueryBuilder rules to server FilterGroup format
        function toServerFormat(qbRules) {
            var result = {
                operator: qbRules.condition === 'OR' ? 'Or' : 'And',
                conditions: [],
                groups: []
            };

            if (qbRules.rules) {
                qbRules.rules.forEach(function (rule) {
                    if (rule.rules) {
                        // Nested group
                        result.groups.push(toServerFormat(rule));
                    } else {
                        // Leaf condition
                        var value = rule.value;
                        if (Array.isArray(value)) {
                            value = value.join(',');
                        }
                        result.conditions.push({
                            field: rule.id,
                            operator: operatorMap[rule.operator] || 'Equal',
                            value: String(value)
                        });
                    }
                });
            }

            return result;
        }

        function countConditions(group) {
            if (!group || !group.rules) {
                return 0;
            }

            var count = 0;
            group.rules.forEach(function (rule) {
                if (rule.rules) {
                    count += countConditions(rule);
                } else {
                    count++;
                }
            });
            return count;
        }

        function setLimitWarning(message) {
            var warning = $('#filter-limit-warning');
            if (message) {
                warning.text(message).removeClass('d-none');
            } else {
                warning.addClass('d-none').text('');
            }
        }

        $('#btn-filter-apply').on('click', function () {
            var result = $('#query-builder').queryBuilder('getRules');
            if (result && !$.isEmptyObject(result)) {
                if (countConditions(result) > maxConditions) {
                    setLimitWarning('Filter supports up to ' + maxConditions + ' conditions.');
                    return;
                }

                setLimitWarning(null);
                var serverFormat = toServerFormat(result);
                var filterJson = JSON.stringify(serverFormat);
                var url = new URL(window.location.href);
                url.searchParams.set('filter', filterJson);
                window.location.href = url.toString();
            }
        });

        $('#btn-filter-clear').on('click', function () {
            $('#query-builder').queryBuilder('reset');
            setLimitWarning(null);
            var url = new URL(window.location.href);
            url.searchParams.delete('filter');
            window.location.href = url.toString();
        });
    })();
</script>
