@{
    ViewData["Title"] = "Journal";
    ViewData["PrimaryAction"] = "create";
}

<div class="container-xl">
    <div class="row row-cards">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <div class="d-flex align-items-center gap-2">
                        <button class="btn btn-outline-secondary btn-sm" id="btn-prev-year">
                            <i class="fas fa-chevron-left"></i>
                        </button>
                        <h3 class="card-title mb-0" id="calendar-year-title"></h3>
                        <button class="btn btn-outline-secondary btn-sm" id="btn-next-year">
                            <i class="fas fa-chevron-right"></i>
                        </button>
                        <button class="btn btn-outline-primary btn-sm ms-2" id="btn-today-year">Today</button>
                    </div>
                </div>
                <div class="card-body">
                    <div id="journal-calendar"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        #journal-calendar .fc-multimonth-daygrid-table .fc-day-today {
            background-color: rgba(var(--tblr-primary-rgb), 0.1);
        }
        #journal-calendar .fc-event {
            cursor: pointer;
        }
        #journal-calendar .fc-day {
            cursor: pointer;
        }
    </style>
}

@section Scripts {
    <script src="~/lib/fullcalendar/index.global.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var calendarEl = document.getElementById('journal-calendar');
            var yearTitle = document.getElementById('calendar-year-title');

            var entryMap = new Map();

            var calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'multiMonthYear',
                multiMonthMaxColumns: 3,
                headerToolbar: false,
                height: 'auto',
                events: '/Journals/CalendarEvents',
                eventDisplay: 'background',
                eventColor: 'var(--tblr-primary)',
                eventDidMount: function (info) {
                    info.el.setAttribute('title', 'Journal entry');
                },
                eventsSet: function (events) {
                    entryMap.clear();
                    events.forEach(function (event) {
                        entryMap.set(event.startStr, event.extendedProps.entryId ?? null);
                    });
                },
                dateClick: function (info) {
                    var entryId = entryMap.get(info.dateStr);
                    if (entryId) {
                        window.location.href = '/Journals/Details/' + entryId;
                    } else {
                        window.location.href = '/Journals/Create?date=' + info.dateStr;
                    }
                },
                datesSet: function (info) {
                    yearTitle.textContent = info.view.currentStart.getFullYear();
                }
            });

            calendar.render();

            document.getElementById('btn-prev-year').addEventListener('click', function () {
                calendar.prev();
            });

            document.getElementById('btn-next-year').addEventListener('click', function () {
                calendar.next();
            });

            document.getElementById('btn-today-year').addEventListener('click', function () {
                calendar.today();
            });
        });
    </script>
}
